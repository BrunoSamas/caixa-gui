datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        String      @id @default(uuid())
  name      String
  price     Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  lines     OrderLine[]
}

model CustomerOrder {
  id            String      @id @default(uuid())
  clientName    String
  status        String      @default("OPEN") // "OPEN", "CLOSED" ou "CANCELLED"
  paymentMethod String?     // "PIX", "DINHEIRO", "DEBITO", "CREDITO"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderLine[]

  @@index([status, createdAt])
}

model OrderLine {
  id              String        @id @default(uuid())
  quantity        Int           @default(1)
  unitPrice       Float
  customerOrderId String
  productId       String
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([customerOrderId])
  @@index([productId])
}

model CashTransaction {
  id          String   @id @default(uuid())
  type        String   // "SUPRIMENTO", "SANGRIA", "SAIDA"
  amount      Float
  description String
  createdAt   DateTime @default(now())

  @@map("transacoes_caixa")
}

model DailyClosing {
  id                 String    @id @default(uuid())
  caixaId            String    @default("Principal") @map("caixa_id")
  usuarioId          String    @default("Operador Padrão") @map("usuario_id")
  data               DateTime  @unique // Data do dia (sem hora)
  abertura           DateTime  @default(now())
  fechamento         DateTime?
  saldoInicial       Float     @default(0) @map("saldo_inicial")
  totalEntradas      Float     @default(0) @map("total_entradas")
  totalSaidas        Float     @default(0) @map("total_saidas")
  totalSangrias      Float     @default(0) @map("total_sangrias")
  totalSuprimentos   Float     @default(0) @map("total_suprimentos")
  totalCancelamentos Float     @default(0) @map("total_cancelamentos")
  totalDinheiro      Float     @default(0) @map("total_dinheiro")
  totalPix           Float     @default(0) @map("total_pix")
  totalDebito        Float     @default(0) @map("total_debito")
  totalCredito       Float     @default(0) @map("total_credito")
  totalVale          Float     @default(0) @map("total_vale")
  totalOutros        Float     @default(0) @map("total_outros")
  saldoEsperado      Float     @default(0) @map("saldo_esperado")
  saldoInformado     Float     @default(0) @map("saldo_informado")
  diferenca          Float     @default(0)
  observacoes        String?
  status             String    @default("OPEN") // "OPEN", "CLOSED", "REOPENED"
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("fechamentos_caixa")
}

model AuditLog {
  id        String   @id @default(uuid())
  usuarioId String   @default("Operador Padrão") @map("usuario_id")
  acao      String   @map("acao") // "ABERTURA", "FECHAMENTO", "REABERTURA", "IMPRESSAO", "ALTERACAO"
  dataHora  DateTime @default(now()) @map("data_hora")
  ip        String?
  detalhes  String?

  @@map("logs_auditoria")
}
