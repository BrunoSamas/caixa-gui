datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        String      @id @default(uuid())
  name      String
  price     Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  lines     OrderLine[]
}

model CustomerOrder {
  id            String      @id @default(uuid())
  clientName    String
  status        String      @default("OPEN") // "OPEN" ou "CLOSED"
  paymentMethod String?     // "PIX", "DINHEIRO", "DEBITO", "CREDITO"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderLine[]

  @@index([status, createdAt])
}

model OrderLine {
  id              String        @id @default(uuid())
  quantity        Int           @default(1)
  unitPrice       Float
  customerOrderId String
  productId       String
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([customerOrderId])
  @@index([productId])
}

model DailyClosing {
  id                 String    @id @default(uuid())
  data               DateTime  @unique // Data do dia (sem hora)
  fechamento         DateTime  @default(now())
  usuarioId          String    @default("Operador") @map("usuario_id")
  totalComandas      Int       @default(0) @map("total_comandas")
  totalVendido       Float     @default(0) @map("total_vendido")
  totalPendente      Float     @default(0) @map("total_pendente")
  totalDinheiro      Float     @default(0) @map("total_dinheiro")
  totalPix           Float     @default(0) @map("total_pix")
  totalDebito        Float     @default(0) @map("total_debito")
  totalCredito       Float     @default(0) @map("total_credito")
  totalOutros        Float     @default(0) @map("total_outros")
  unpaidClientsJson  String    @default("[]") @map("clientes_pendentes_json")

  @@map("fechamentos_dia")
}
